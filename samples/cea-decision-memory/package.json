{
  "name": "decision-memory-agent",
  "version": "0.1.0",
  "description": "Decision Memory — an institutional-memory custom engine agent for Microsoft 365 Copilot Chat and Teams. No Microsoft 365 Copilot license required.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "env-cmd -f env/.env.local -- env-cmd --silent -f env/.env.local.user -- tsx watch src/index.ts",
    "dev:inspect": "node --inspect=9239 --import tsx src/index.ts",
    "dev:mcp": "tsx watch src/mcp/server.ts",
    "dev:teamsfx": "env-cmd --silent -f .localConfigs -- npm run dev:inspect",
    "dev:teamsfx:playground": "env-cmd --silent -f .localConfigs.playground -- npm run dev:inspect",
    "dev:teamsfx:launch-playground": "env-cmd --silent -f env/.env.playground -- teamsapptester start",
    "start": "node dist/src/index.js",
    "start:mcp": "node dist/src/mcp/server.js",
    "playground": "teamsapptester start",
    "test": "vitest run",
    "smoke": "tsx scripts/smoke.ts",
    "demo:reset": "node -e \"require('fs').rmSync('data/decisions.runtime.json',{force:true});console.log('Runtime decision state cleared - store is back to the 14 seed records.')\""
  },
  "dependencies": {
    "@azure/storage-blob": "^12.32.0",
    "@microsoft/agents-activity": "^1.5.3",
    "@microsoft/agents-hosting": "^1.5.3",
    "@microsoft/agents-hosting-express": "^1.5.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "openai": "^6.42.0",
    "zod": "^3.25.75"
  },
  "devDependencies": {
    "@microsoft/m365agentsplayground": "^0.2.27",
    "@types/express": "^5.0.0",
    "@types/node": "^22",
    "azurite": "^3.35.0",
    "env-cmd": "^11.0.0",
    "tsx": "^4",
    "typescript": "^5.7",
    "vitest": "^3"
  }
}
