# Remote environment (org-wide publish). Placeholders only — no secrets.
TEAMSFX_ENV=dev
APP_NAME_SUFFIX=


BOT_ID= 
TEAMS_APP_ID=   
BOT_DOMAIN= 
BOT_ENDPOINT=   
TEAMS_APP_TENANT_ID=    
BOT_OBJECT_ID=  
M365_TITLE_ID=
M365_APP_ID=






MCP_SERVER_URL=http://localhost:3979/mcp

# Run with the deterministic offline LLM so no credentials are needed, if marked as true no below values needed to be filled and if SECRET_AZURE_STORAGE_CONNECTION_STRING is empty it will default to using local file system for storage.
# Set to false (and provide Azure OpenAI vars) to use a real model.
USE_FAKE_LLM=false


AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21
SECRET_AZURE_STORAGE_CONNECTION_STRING=
TEAMS_APP_TENANT_ID=
BOT_TENANT_ID=